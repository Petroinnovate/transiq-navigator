# ===========================================
# TransIQ Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values

# ============================================
# 🔐 SECURITY (CRITICAL - Required for Production)
# ============================================
# Generate secure API keys: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here-CHANGE-THIS
API_KEY_2=backup-api-key-optional
API_KEY_3=additional-api-key-optional

# JWT Token secret (for user authentication)
# If not set, uses API_KEY as JWT secret
# JWT_SECRET_KEY=your-jwt-secret-here-64-chars-recommended

# CORS allowed origin (your frontend URL)
FRONTEND_URL=http://localhost:5173  # Development
# FRONTEND_URL=https://yourdomain.com  # Production

# Rate limiting (requests per minute per API key)
RATE_LIMIT_PER_MINUTE=60

# ============================================
# ⚠️  DEMO DATA Configuration (CRITICAL!)
# ============================================
# DEFAULT (Development): Demo data is returned if cache is empty
# PRODUCTION: Set to false to prevent fake data from being served
ALLOW_DEMO_DATA_FALLBACK=true  # Set to FALSE in production!

# STRICT MODE: Reject requests without real data (set with ALLOW_DEMO_DATA_FALLBACK=false)
REQUIRE_REAL_DATA=false  # Set to TRUE in production for strict mode

# ============================================
# LLM API Configuration (ONLY EXTERNAL DEPENDENCY)
# ============================================
# Add up to 4 Gemini API keys. When one key's daily quota is exhausted 
# the system automatically switches to the next key.
GEMINI_API_KEY=your-gemini-api-key-1-here
GEMINI_API_KEY_2=your-gemini-api-key-2-here
GEMINI_API_KEY_3=your-gemini-api-key-3-here
GEMINI_API_KEY_4=your-gemini-api-key-4-here

# Optional: Add other LLM providers as fallbacks
# OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here

# ============================================
# Database Configuration
# ============================================
# Choose one:
# SQLite (Development - single file database)
DATABASE_URL=sqlite:///./storage/local_storage.db

# PostgreSQL (Production - scalable, multi-user)
# DATABASE_URL=postgresql://user:password@localhost:5432/transiq

# Supabase (Managed PostgreSQL)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ============================================
# LLM API Configuration (ONLY EXTERNAL DEPENDENCY)
# ============================================

# Vector Database (Qdrant) - Runs in Docker
# Leave blank to use Docker service (recommended)
# QDRANT_URL=http://qdrant:6333
# USE_LOCAL_QDRANT=false

# Embedding Model (Downloaded once, cached locally)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Database (SQLite, stored locally)
# DATABASE_URL=sqlite:///./storage/local_storage.db

# Redis (Docker service, no configuration needed)
# REDIS_URL=redis://redis:6379/0

# ============================================
# Optional: Supabase (NOT RECOMMENDED - adds external dependency)
# ============================================
# ENABLE_SUPABASE=false
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Optional: Advanced Settings
# ============================================
# CHUNK_SIZE=10000
# CHUNK_OVERLAP=400
# DEFAULT_SEARCH_TOP_K=10
# DEBUG=false

